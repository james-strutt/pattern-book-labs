    "id": "LLA01",
    "name": "Large Lot Apartments 01",
    "architect": "Silvester Fuller",
    "version": "1.0",
    "releaseDate": "2025-11-01",
    "developmentType": "residential_flat_building",
    "description": "A bold and sculptural apartment building with generous light-filled apartments and sweeping curved balconies that dissolve the threshold between inside and outside.",
    "designConcepts": [
      "Expressive curved building with generously sized apartments as house alternative",
      "Wide balconies suitable for indoor-outdoor living and passive climate control",
      "Dedicated communal spaces on each floor level for social gathering",
      "Integrated arrival space and open circulation stair for intuitive wayfinding",
      "Adaptable floorplates including dual-key apartments for multigenerational living",
      "Integrated sustainability features including solar access and cross-ventilation"
    ],
    "ownershipTypes": ["strata", "company_title", "build_to_rent"],
    "applicablePolicies": [
      {
        "name": "Housing SEPP Chapter 7",
        "description": "Pattern book development under State Environmental Planning Policy (Housing) 2021"
