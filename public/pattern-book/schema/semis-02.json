    "name": "Semis 02",
    "architect": "Sibling Architecture",
    "version": "1.0",
    "releaseDate": "2025-11-01",
    "developmentType": "dual_occupancy",
    "buildingClass": "1a",
    "description": "An uplifting and fresh design with living spaces that connect to the garden and central courtyard. Features a courtyard between the kitchen and living room bringing light, fresh air and a green outlook into the centre of the house.",
    "designConcepts": [
      "Individual identity for each home with distinct colours and stepped facade",
      "Central courtyard bringing light, fresh air and green outlook into the house",
      "Living areas with strong physical and visual connection to private rear garden",
      "Efficient and well-planned spaces to maximise available site area",
      "Two storeys to street and single storey to rear to improve amenity to neighbours",
      "Sculptural window hoods to protect from rain and sun",
      "Brickwork on ground floor for solidity, texture and low maintenance"
    ],
    "ownershipTypes": ["torrens_title"],
    "applicablePolicies": [
      {
        "name": "Housing SEPP Chapter 7",
        "description": "Pattern book development under State Environmental Planning Policy (Housing) 2021"
      },
