{
  "$schema": "./pattern-book-schema.json",
  "metadata": {
    "id": "LLA02",
    "name": "Large Lot Apartments 02",
    "architect": "Bennett and Trimble",
    "version": "1.0",
    "releaseDate": "2025-11-01",
    "developmentType": "residential_flat_building",
    "description": "A courtyard design that combines two familiar housing types, the terrace and the apartment, into a contemporary and flexible pattern for large lots.",
    "designConcepts": [
      "Flexible design combining terrace typology with articulated corner blocks",
      "Strong street presence on both primary and secondary street frontages",
      "Central landscaped courtyard providing amenity and social interaction",
      "Landscape buffers enhancing privacy, walkability and supporting mature trees",
      "Modular bays allowing adjustment to different lot widths",
      "Integrated sustainability principles including solar access and cross-ventilation"
    ],
    "ownershipTypes": ["strata", "company_title", "build_to_rent"],
    "applicablePolicies": [
      {
        "name": "Housing SEPP Chapter 7",
        "description": "Pattern book development under State Environmental Planning Policy (Housing) 2021"
      },
      {
        "name": "Low and Mid-Rise Housing Areas",
        "reference": "Section 163 Housing SEPP"
      },
      {
        "name": "Transport Oriented Development Areas",
        "reference": "Chapter 5 Housing SEPP"
      }
    ]
  },

  "siteEligibility": {
    "siteTypes": {
      "allowed": ["mid_block", "corner", "end_lot", "through_lot"],
      "excluded": ["battle_axe"]
    },

    "lotDimensions": {
      "absoluteMinimums": {
        "width": 36.0,
        "length": 57.0,
        "area": 2052
      },
      "absoluteMaximums": {
        "width": 172.0,
        "length": 80.0,
        "area": 12040
      }
    },

    "excludedLand": [
      {
        "type": "bushfire_prone",
        "description": "Land identified as bushfire-prone"
      },
      {
        "type": "flood_prone_high_risk",
        "description": "Certain flood-prone land in high risk locations"
      },
      {
        "type": "state_heritage_item",
        "description": "State heritage items"
      },
      {
        "type": "local_heritage_item",
        "description": "Local heritage items"
      },
      {
        "type": "heritage_conservation_area",
        "description": "Heritage conservation areas"
      }
    ],

    "slopeConstraints": {
      "maxCrossfallMetres": 4.0,
      "allowedDirections": ["upslope_to_rear", "downslope_to_rear"],
      "notes": "Flexible points between modules accommodate slopes of 0-4m in either direction"
    }
  },

  "developmentStandards": {
    "height": {
      "maxMetres": 22.0,
      "maxStoreys": 6,
      "minStoreys": 3,
      "exclusionsFromMaxHeight": [
        "lift_overruns",
        "plant_and_services_equipment"
      ],
      "notes": "Stepped height options available from 3 to 6 storeys"
    },

    "setbacks": {
      "front": {
        "primary": {
          "min": 4.0
        },
        "secondary": {
          "min": 4.0
        }
      },
      "rear": {
        "standard": {
          "min": 6.0
        }
      },
      "side": {
        "rules": [
          {
            "id": "3m_setback",
            "conditions": {
              "lotWidthMin": 36.0,
              "lotWidthMax": null
            },
            "setback": 3.0,
            "maxStoreys": 6
          }
        ]
      }
    },

    "dwellings": {
      "max": 216,
      "min": 24,
      "maxSingleTypePercentage": 75,
      "mixRequirement": "No more than 75% of dwellings to be a single type"
    },

    "floorToCeiling": {
      "habitable": {
        "min": 2.7,
        "unit": "metres"
      },
      "nonHabitable": {
        "min": 2.4,
        "unit": "metres"
      }
    },

    "deepSoil": {
      "rules": [
        {
          "siteAreaMax": 650,
          "percentage": 7
        },
        {
          "siteAreaMin": 650,
          "siteAreaMax": 1500,
          "percentage": 10
        },
        {
          "siteAreaMin": 1500,
          "percentage": 15
        }
      ],
      "unit": "percentage_of_site_area"
    },

    "communalOpenSpace": {
      "locations": ["central_courtyard", "rooftop"],
      "features": [
        "through_site_pedestrian_links",
        "landscaped_courtyard",
        "mature_tree_planting"
      ]
    }
  },

