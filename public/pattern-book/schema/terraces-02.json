{
  "$schema": "./pattern-book-schema.json",
  "metadata": {
    "id": "TH02",
    "name": "Terraces 02",
    "architect": "Sam Crawford Architects",
    "version": "1.0",
    "releaseDate": "2025-07-01",
    "developmentType": "multi_dwelling_housing_terraces",
    "buildingClass": "1a",
    "description": "A compact design that maximises landscaped spaces and uses skylights and balconies to bring fresh air and light into each home. The material palette reflects the colours of the Australian environment.",
    "designConcepts": [
      "Efficient interior layouts to create spacious living areas",
      "Living areas directly connected to private garden",
      "Strategically positioned skylights for sunlight and ventilation",
      "Private balcony for principal bedroom",
      "Compact building footprint to prioritise outdoor space",
      "Standard size doors and windows to simplify construction",
      "Material palette reflecting Australian environment colours"
    ],
    "ownershipTypes": ["torrens_title"],
    "applicablePolicies": [
      {
        "name": "Pattern Book Development Code 2025",
        "description": "Pattern book development under State Environmental Planning Policy (Exempt and Complying Development Codes) 2008"
      },
      {
        "name": "Low and Mid-Rise Housing Areas",
        "reference": "Section 163 Housing SEPP"
      },
      {
        "name": "Non-LMR Housing Areas",
        "reference": "Local Environmental Plan provisions"
      }
    ]
  },

  "siteEligibility": {
    "siteTypes": {
      "allowed": ["mid_block", "corner", "rear_laneway"],
      "excluded": ["battle_axe", "irregular"]
    },

