    },

    "solarOrientation": {
      "allOrientationsSupported": true,
      "bestSuited": "north_facing_rear_yards",
      "orientationGuidance": [
        {
          "frontageDirection": "north",
          "notes": "Skylights and flexible street-facing living spaces optimise solar access"
        },
        {
          "frontageDirection": "south",
          "notes": "North-facing rear yards provide optimal solar access"
        },
        {
          "frontageDirection": "east",
          "notes": "Design includes options for east orientation"
        },
        {
          "frontageDirection": "west",
          "notes": "Design includes options for west orientation"
        }
      ]
    }
  },

  "developmentStandards": {
    "height": {
      "lmr": {
        "maxMetres": 9.5,
        "maxStoreys": 3,
        "minStoreys": 2,
        "basePatternHeight": 9.3,
        "notes": "Attic adaptation allowed only in LMR areas"
      },
      "nonLmr": {
        "maxMetres": 9.0,
        "maxStoreys": 2,
        "minStoreys": 2
      },
      "exclusionsFromMaxHeight": [
        "chimneys",
        "flues",
        "domestic_aerials"
      ]
    },

    "setbacks": {
      "front": {
        "lmr": {
          "min": 3.0,
          "notes": "Primary street frontage setback in LMR areas"
        },
        "nonLmr": {
          "min": 7.0,
          "alternativeRule": "Not less than average setback from primary road of nearest 2 dwelling houses within 40m on same side, whichever is greater",
          "notes": "Primary street frontage setback in non-LMR areas"
        }
      },
      "rear": {
        "lmr": {
          "min": 8.8,
          "lanewayException": 0,
          "notes": "0m where laneway garages exist"
        },
        "nonLmr": {
          "min": 8.8,
          "lanewayException": 0.9,
          "notes": "0.9m where laneway garages exist"
        }
      },
      "side": {
        "lmr": {
          "min": 0.9,
          "notes": "Side boundary setback in LMR areas"
        },
        "nonLmr": {
          "min": 1.5,
          "notes": "Side boundary setback in non-LMR areas"
        }
      },
      "secondary": {
        "min": 2.0,
        "notes": "Secondary street setback for corner lots"
      }
    },

    "fsr": {
      "lmr": {
        "max": 0.8,
        "basePattern": 0.68,
        "notes": "Maximum 0.8:1 when selecting all adaptations; base pattern is 0.68:1"
      },
      "nonLmr": {
        "max": 0.6,
        "basePattern": 0.55,
        "notes": "Maximum 0.6:1 when selecting all adaptations; base pattern is 0.55:1"
      }
    },

    "streetFrontage": {
      "maxUnbroken": 45,
      "unit": "metres"
    },

    "dwellings": {
      "min": 3,
      "max": 3,
      "configuration": "terraces",
      "bedroomOptions": [2, 3, 4]
    },

    "floorToCeiling": {
      "habitable": {
        "min": 2.7,
        "unit": "metres"
      },
      "nonHabitable": {
        "min": 2.4,
        "unit": "metres"
      }
    },

    "landscapeRequirements": {
      "minPercentage": 20,
      "guideReference": "NSW Housing Pattern Book Landscape design guide",
      "treeCanopyGuide": "NSW Government Tree Canopy Guide for Low and Mid Rise Housing"
    },

    "parking": {
      "lmr": {
        "spacesPerDwelling": 0.5,
        "notes": "As defined by LMR reforms"
      },
      "nonLmr": {
        "spacesPerDwelling": 1,
        "notes": "Minimum 1 car parking space per dwelling"
      },
      "maxGaragesPerPattern": 2,
      "notes": "Max 2 out of 3 dwellings may incorporate a garage. Parking alternatively provided as hardstand for non-LMR areas."
    }
