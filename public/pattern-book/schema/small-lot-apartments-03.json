{
  "$schema": "./pattern-book-schema.json",
  "metadata": {
    "id": "SLA03",
    "name": "Small Lot Apartments 03",
    "architect": "MHN Design Union",
    "version": "1.0",
    "releaseDate": "2025-11-01",
    "developmentType": "residential_flat_building",
    "description": "A sophisticated apartment building with a dynamic facade, modular layout and a range of one and two storey house-like dwellings.",
    "designConcepts": [
      "Contemporary take on a modernist apartment building with rational layouts",
      "Spacious and light-filled dwellings including 1-storey and 2-storey homes",
      "Diverse mix of studio to 4-bedroom dwellings",
      "Ample private balconies or courtyards on each floor level",
      "Flexible communal spaces on alternate floors including rooftop",
      "Integrated sustainable performance including solar access and cross-ventilation"
    ],
    "ownershipTypes": ["strata", "company_title", "build_to_rent"],
    "applicablePolicies": [
      {
        "name": "Housing SEPP Chapter 7",
        "description": "Pattern book development under State Environmental Planning Policy (Housing) 2021"
      },
      {
        "name": "Low and Mid-Rise Housing Areas",
        "reference": "Section 163 Housing SEPP"
      },
      {
        "name": "Transport Oriented Development Areas",
        "reference": "Chapter 5 Housing SEPP"
      }
    ]
  },

  "siteEligibility": {
    "siteTypes": {
      "allowed": ["mid_block", "mid_block_laneway"],
      "excluded": ["corner", "battle_axe"]
    },

    "lotDimensions": {
      "absoluteMinimums": {
        "width": 16.0,
        "length": 40.0,
        "area": 640
      },
      "absoluteMaximums": {
        "width": 19.8,
        "length": 65.0,
        "area": 1287
      }
    },

    "excludedLand": [
      {
        "type": "bushfire_prone",
