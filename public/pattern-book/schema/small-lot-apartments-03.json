      },
      {
        "type": "flood_prone_high_risk",
        "description": "Certain flood-prone land in high risk locations"
      },
      {
        "type": "state_heritage_item",
        "description": "State heritage items"
      },
      {
        "type": "local_heritage_item",
        "description": "Local heritage items"
      },
      {
        "type": "heritage_conservation_area",
        "description": "Heritage conservation areas"
      }
    ],

    "slopeConstraints": {
      "maxCrossfallMetres": 2.25,
      "allowedDirections": ["upslope_to_rear", "downslope_to_rear"],
      "notes": "Can adapt to sloping sites with a level change of up to 2.25m upslope and 0.65m downslope"
    }
  },

  "developmentStandards": {
    "height": {
      "maxMetres": 22.0,
      "maxStoreys": 6,
      "minStoreys": 4,
      "exclusionsFromMaxHeight": [
        "lift_overruns",
        "plant_and_services_equipment",
        "shade_structures"
      ]
    },

    "setbacks": {
