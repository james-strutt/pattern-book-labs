          "min": 4.0
        }
      },
      "rear": {
        "standard": {
          "min": 6.0
        }
      },
      "side": {
        "rules": [
          {
            "id": "3m_setback",
            "conditions": {
              "lotWidthMin": 16.0,
              "lotWidthMax": null
            },
            "setback": 3.0,
            "maxStoreys": 6
          }
        ]
      }
    },

    "dwellings": {
      "max": 24,
      "min": 9,
      "maxSingleTypePercentage": 75,
      "mixRequirement": "No more than 75% of dwellings to be a single type"
    },

    "floorToCeiling": {
      "habitable": {
        "min": 2.7,
        "unit": "metres"
      },
      "nonHabitable": {
        "min": 2.4,
        "unit": "metres"
      }
    },

    "deepSoil": {
