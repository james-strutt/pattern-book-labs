        {
          "siteAreaMax": 650,
          "percentage": 7
        },
        {
          "siteAreaMin": 650,
          "siteAreaMax": 1500,
          "percentage": 10
        },
        {
          "siteAreaMin": 1500,
          "percentage": 15
        }
      ],
      "unit": "percentage_of_site_area"
    }
  },

