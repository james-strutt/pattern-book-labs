{
  "$schema": "./pattern-book-schema.json",
  "metadata": {
    "id": "SLA04",
    "name": "Small Lot Apartments 04",
    "architect": "Neeson Murcutt Neille",
    "version": "1.0",
    "releaseDate": "2025-11-01",
    "developmentType": "residential_flat_building",
    "description": "A refined, efficiently planned apartment building with a 'breezy core' and common space that fits harmoniously into existing residential neighbourhoods.",
    "designConcepts": [
      "Neighbourly 4-5 storey building designed to sensitively fit 5 storeys into a typical 4-storey envelope",
      "Refined and durable material palettes with bright awnings and pops of colour",
      "Mix of studio to 3-bedroom dwellings with interchangeable floor plates",
      "Breezy shared circulation spaces that are covered but open to outdoors",
      "Communal and private gardens with generous deep soil provisions",
      "Competition-winning design reflecting the NSW Apartment Design Guide"
    ],
    "ownershipTypes": ["strata", "company_title", "build_to_rent"],
    "applicablePolicies": [
      {
        "name": "Housing SEPP Chapter 7",
        "description": "Pattern book development under State Environmental Planning Policy (Housing) 2021"
      },
      {
        "name": "Low and Mid-Rise Housing Areas",
        "reference": "Section 163 Housing SEPP"
      },
      {
        "name": "Transport Oriented Development Areas",
        "reference": "Chapter 5 Housing SEPP"
      }
    ]
  },

