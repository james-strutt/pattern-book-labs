{
  "$schema": "./pattern-book-schema.json",
  "metadata": {
    "id": "SLA01",
    "name": "Small Lot Apartments 01",
    "architect": "Collins and Turner",
    "version": "1.0",
    "releaseDate": "2025-11-01",
    "developmentType": "residential_flat_building",
    "description": "A timeless, compact design that integrates Art Deco sensibilities with the conveniences of modern living. A contemporary take on the classic Art Deco walk-up, distinguished by its elegant brick facade.",
    "designConcepts": [
      "Efficient floor plate to maximise apartments on compact site",
      "Mix of studio to 4-bedroom homes with flexible multipurpose rooms",
      "Private balconies and courtyards with communal rooftop and rear garden",
      "Integrated sustainability features including solar access, cross-ventilation, rainwater tanks and solar panels",
      "Stacked and standardised wet areas for construction efficiency",
      "Cost-balanced facades with brick at street edge, lightweight at boundaries"
    ],
    "ownershipTypes": ["strata", "company_title", "build_to_rent"],
    "applicablePolicies": [
      {
        "name": "Housing SEPP Chapter 7",
        "description": "Pattern book development under State Environmental Planning Policy (Housing) 2021"
      },
      {
        "name": "Low and Mid-Rise Housing Areas",
        "reference": "Section 163 Housing SEPP"
      },
      {
        "name": "Transport Oriented Development Areas",
        "reference": "Chapter 5 Housing SEPP"
      }
    ]
  },

  "siteEligibility": {
    "siteTypes": {
      "allowed": ["mid_block", "mid_block_laneway"],
      "excluded": ["corner", "battle_axe"]
    },

    "lotDimensions": {
      "absoluteMinimums": {
        "width": 13.0,
        "length": 40.0,
        "area": 520
      },
      "absoluteMaximums": {
        "width": null,
        "length": 54.5,
        "area": 904
      }
    },

    "excludedLand": [
      {
        "type": "bushfire_prone",
        "description": "Land identified as bushfire-prone"
      },
      {
        "type": "flood_prone_high_risk",
        "description": "Certain flood-prone land in high risk locations"
      },
      {
        "type": "state_heritage_item",
        "description": "State heritage items"
      },
      {
        "type": "local_heritage_item",
        "description": "Local heritage items"
      },
      {
        "type": "heritage_conservation_area",
        "description": "Heritage conservation areas"
      }
    ],

    "slopeConstraints": {
      "maxCrossfallMetres": 1.0,
      "allowedDirections": ["upslope_to_rear", "downslope_to_rear"],
      "notes": "Basement and ground floor layouts can adjust to site slopes of up to 1m"
    },

    "solarOrientation": {
      "allOrientationsSupported": true,
      "orientationGuidance": [
        {
          "frontageDirection": "north",
          "mirroring": "vertical",
          "parkingAccessOptions": ["rear_lane", "no_parking"],
          "notes": "North frontage requires vertical mirroring, parking access from rear lane only"
        },
        {
          "frontageDirection": "south",
          "mirroring": "none",
          "parkingAccessOptions": ["front_street", "rear_lane", "no_parking"],
          "notes": "Base pattern orientation"
        },
        {
          "frontageDirection": "east",
          "mirroring": "none",
          "parkingAccessOptions": ["front_street", "rear_lane", "no_parking"],
          "notes": "Base pattern works directly"
        },
        {
          "frontageDirection": "west",
          "mirroring": "horizontal",
          "parkingAccessOptions": ["front_street", "rear_lane", "no_parking"],
          "notes": "West frontage requires horizontal mirroring"
        }
      ]
    }
  },

  "developmentStandards": {
    "height": {
      "maxMetres": 17.5,
      "maxStoreys": 4,
      "minStoreys": 3,
      "exclusionsFromMaxHeight": [
        "lift_overruns",
        "plant_and_services_equipment",
        "shade_structures",
        "common_floor_area",
        "communal_open_space"
      ],
      "additionalHeightForExclusions": 1.45,
      "notes": "Maximum building height for pattern includes allowance for adaptation to slope on subject site"
    },

    "setbacks": {
      "front": {
        "primary": {
          "min": 4.0,
          "notes": "Primary street frontage"
        }
      },
      "rear": {
        "standard": {
          "min": 6.0
        },
        "parallelStreetOrLaneway": {
          "min": 6.0
        }
      },
      "side": {
        "rules": [
          {
            "id": "0m_setback",
            "conditions": {
              "lotWidthMin": 13.0,
              "lotWidthMax": 16.0,
              "wallType": "blank_wall_portion"
            },
            "setback": 0,
            "windowedPortionSetback": 3.0,
            "maxStoreys": 4,
            "notes": "0m setback where blank wall faces boundary, 3m where windows face side boundary"
          },
          {
            "id": "1.5m_setback",
            "conditions": {
              "lotWidthMin": 13.6,
              "lotWidthMax": 16.5
            },
            "setback": 1.5,
            "maxStoreys": 3,
            "notes": "Continuous side setback for 3-storey buildings"
          },
          {
            "id": "2.0m_setback",
            "conditions": {
              "lotWidthMin": 14.6,
              "lotWidthMax": 15.5
            },
            "setback": 2.0,
            "maxStoreys": 3,
            "notes": "Increased setback for wider lots"
          },
          {
            "id": "2.5m_setback",
            "conditions": {
              "lotWidthMin": 15.6,
              "lotWidthMax": 16.5
            },
            "setback": 2.5,
            "maxStoreys": 3,
            "notes": "Increased setback for wider lots"
          },
          {
            "id": "3.0m_setback",
            "conditions": {
              "lotWidthMin": 16.6,
              "lotWidthMax": null
            },
            "setback": 3.0,
            "maxStoreys": 4,
            "notes": "Full setback for 4-storey buildings"
          }
        ],
        "allowableEncroachments": ["window_hoods"]
      }
    },

    "dwellings": {
      "max": 13,
      "min": 7,
      "maxSingleTypePercentage": 75,
      "mixRequirement": "No more than 75% of dwellings to be a single type"
    },

    "floorToCeiling": {
      "habitable": {
        "min": 2.7,
        "unit": "metres"
      },
      "nonHabitable": {
        "min": 2.4,
        "unit": "metres"
      }
    },

    "deepSoil": {
      "rules": [
        {
          "siteAreaMax": 650,
          "percentage": 7
        },
        {
          "siteAreaMin": 650,
          "siteAreaMax": 1500,
          "percentage": 10
        },
        {
          "siteAreaMin": 1500,
          "percentage": 15
        }
      ],
      "unit": "percentage_of_site_area"
    },

    "solarAccess": {
      "minPercentageOfDwellingsCompliant": 70,
      "minDirectSunlightHours": 2,
      "timeWindow": {
        "start": "08:00",
        "end": "16:00"
      },
      "targetArea": "living_spaces",
      "notes": "Pattern achieves at least 70% solar access between 8am to 4pm under common conditions"
    },

    "overshadowing": {
      "neighbouringProperties": {
        "minSunlightHours": 3,
        "minPrivateOpenSpacePercentage": 50,
        "timeWindow": {
          "start": "09:00",
          "end": "15:00"
        },
        "referenceDate": "21 June"
      },
      "evidenceRequired": "sun_shadow_diagrams",
      "notes": "Setbacks may need to be increased to maximise solar access and minimise overshadowing"
    },

    "crossVentilation": {
      "required": true,
      "standard": "ADG_compliant",
      "notes": "All apartments achieve cross-ventilation in accordance with ADG guidance"
    },

    "communalOpenSpace": {
      "minPercentageOfSiteArea": 28,
      "locations": ["ground_floor_courtyard", "rooftop"],
      "features": [
        "outdoor_gym",
        "outdoor_benches_with_shade",
        "vegetable_garden_with_dining",
        "playground_with_pergola",
        "outdoor_kitchen"
      ]
    },

    "landscapeRequirements": {
      "guideReference": "NSW Housing Pattern Book Landscape design guide",
      "treeCanopyRequired": true,
      "significantTreesNote": "Sites requiring change, removal or pruning of significant trees must seek council approval"
    },

    "privacyRequirements": {
      "addressedInPattern": true,
      "solutions": [
        "fixed_screening",
        "optional_screening",
        "required_setbacks_for_building_separation",
        "reeded_or_translucent_glazing_at_boundaries",
        "clear_sashless_windows_perpendicular_to_boundaries"
      ]
    }
  },

