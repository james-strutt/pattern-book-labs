{
  "$schema": "./pattern-book-schema.json",
  "metadata": {
    "id": "SLA02",
    "name": "Small Lot Apartments 02",
    "architect": "Nguluway DesignInc",
    "version": "1.0",
    "releaseDate": "2025-11-01",
    "developmentType": "residential_flat_building",
    "description": "A sculptural apartment building with earthy material palette and thoughtful in-between spaces for neighbours to connect with Country and each other.",
    "designConcepts": [
      "Earthy materials and colours that reflect and respond to local Country",
      "Communal 'brackish spaces' on each level for residents to meet and interact",
      "Mix of generous 1-bedroom, 2-bedroom and 3-bedroom homes",
      "Integrated sustainability including solar access, cross-ventilation, rainwater tanks and solar panels",
      "Family-friendly design adaptable to a range of settings in NSW"
    ],
    "ownershipTypes": ["strata", "company_title", "build_to_rent"],
    "applicablePolicies": [
      {
        "name": "Housing SEPP Chapter 7",
        "description": "Pattern book development under State Environmental Planning Policy (Housing) 2021"
      },
      {
        "name": "Low and Mid-Rise Housing Areas",
        "reference": "Section 163 Housing SEPP"
      },
      {
        "name": "Transport Oriented Development Areas",
        "reference": "Chapter 5 Housing SEPP"
      }
    ]
  },

